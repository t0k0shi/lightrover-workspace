# Lightrover テレメトリダッシュボード 環境変数テンプレート
#
# 使い方:
#   cp .env.example .env
#   .env を編集してパスワードとトークンを変更する
#   .env は .gitignore で除外済み（リポジトリにコミットしない）

# ---- InfluxDB ----
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=change-me-before-seminar
INFLUXDB_ORG=lightrover
INFLUXDB_BUCKET=seminar
INFLUXDB_RETENTION=720h
# トークンは英数字・記号混在の十分な長さで生成すること
INFLUXDB_TOKEN=change-me-before-seminar-token

# ---- Grafana ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-before-seminar
