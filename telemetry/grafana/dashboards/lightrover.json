{
  "uid": "lightrover-telemetry",
  "title": "Lightrover テレメトリ",
  "description": "Lightrover 走行データのリアルタイム可視化（速度・位置・軌跡）",
  "editable": true,
  "schemaVersion": 38,
  "timezone": "browser",
  "refresh": "5s",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "liveNow": true,
  "tags": ["lightrover", "ros2", "telemetry"],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "InfluxDB-Lightrover",
          "value": "InfluxDB-Lightrover"
        },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "influxdb",
        "refresh": 1,
        "type": "datasource",
        "label": "Data Source"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "速度: 指令 vs 実測",
      "description": "linear_x 指令値（cmd_vel）と実測速度（odom）の比較",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "query": "from(bucket: \"seminar\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cmd_vel\")\n  |> filter(fn: (r) => r._field == \"linear_x\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"指令\")",
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "query": "from(bucket: \"seminar\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"robot_telemetry\")\n  |> filter(fn: (r) => r._field == \"speed\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"実測\")",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "velocityms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "lineInterpolation": "linear",
            "showPoints": "auto",
            "pointSize": 5
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [
              { "id": "displayName", "value": "指令 (cmd_vel)" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#e02f44" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "displayName", "value": "実測 (odom)" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794F2" } },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "title": "角速度: 指令 vs 実測",
      "description": "angular_z 指令値（cmd_vel）と実測値（odom）の比較",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "query": "from(bucket: \"seminar\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cmd_vel\")\n  |> filter(fn: (r) => r._field == \"angular_z\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"指令\")",
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "query": "from(bucket: \"seminar\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"robot_telemetry\")\n  |> filter(fn: (r) => r._field == \"angular_z\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"実測\")",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "rotradps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "lineInterpolation": "linear",
            "showPoints": "auto",
            "pointSize": 5
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [
              { "id": "displayName", "value": "指令 (cmd_vel)" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#e02f44" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "displayName", "value": "実測 (odom)" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794F2" } },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "title": "現在速度",
      "description": "リアルタイム走行速度（0〜0.6 m/s）",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "query": "from(bucket: \"seminar\")\n  |> range(start: -5s)\n  |> filter(fn: (r) => r._measurement == \"robot_telemetry\")\n  |> filter(fn: (r) => r._field == \"speed\")\n  |> last()",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "velocityms",
          "min": 0,
          "max": 0.6,
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 4,
      "title": "現在角速度",
      "description": "リアルタイム角速度（-2.0〜2.0 rad/s）",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "query": "from(bucket: \"seminar\")\n  |> range(start: -5s)\n  |> filter(fn: (r) => r._measurement == \"robot_telemetry\")\n  |> filter(fn: (r) => r._field == \"angular_z\")\n  |> last()",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "rotradps",
          "min": -2,
          "max": 2,
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.0 },
              { "color": "red", "value": 1.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 5,
      "title": "ロボット姿勢 (yaw)",
      "description": "ヨー角 -180°〜180°（デッドレコニング）",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "query": "from(bucket: \"seminar\")\n  |> range(start: -5s)\n  |> filter(fn: (r) => r._measurement == \"robot_telemetry\")\n  |> filter(fn: (r) => r._field == \"yaw\")\n  |> last()\n  |> map(fn: (r) => ({r with _value: r._value * 57.29577951}))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "degree",
          "min": -180,
          "max": 180,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 7,
      "title": "総走行距離",
      "description": "速度の時間積分による累積走行距離",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "query": "from(bucket: \"seminar\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"robot_telemetry\")\n  |> filter(fn: (r) => r._field == \"speed\")\n  |> integral(unit: 1s)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "lengthm",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "title": "走行軌跡",
      "description": "pos_x / pos_y の 2D 散布図（オドメトリドリフトあり）",
      "type": "xychart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "query": "from(bucket: \"seminar\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"robot_telemetry\")\n  |> filter(fn: (r) => r._field == \"pos_x\" or r._field == \"pos_y\")\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "lengthm",
          "custom": {
            "show": "points+lines",
            "pointSize": {
              "fixed": 4
            },
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "dims": {
          "x": "pos_x"
        },
        "seriesMapping": "auto",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 8,
      "title": "位置 X/Y 時系列",
      "description": "pos_x・pos_y の時間変化",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "influxdb", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "query": "from(bucket: \"seminar\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"robot_telemetry\")\n  |> filter(fn: (r) => r._field == \"pos_x\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"pos_x\")",
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${datasource}" },
          "query": "from(bucket: \"seminar\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"robot_telemetry\")\n  |> filter(fn: (r) => r._field == \"pos_y\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"pos_y\")",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "lengthm",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "lineInterpolation": "linear",
            "showPoints": "auto",
            "pointSize": 5
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [
              { "id": "displayName", "value": "pos_x" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794F2" } }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "displayName", "value": "pos_y" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
